--- !u!114 &222917618
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 222917617}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: bf9b7667834d5df9090cf47abf407048, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  backButton: {fileID: 413879781}
  fadeOverlay: {fileID: 627881898}
  fadeDuration: 0.5
  coinIconSprite: {fileID: 21300000, guid: 53831ffd2c1064d07b3fcc10982b1e0d, type: 3}
  cardsGridParent: {fileID: 181513275}
  plantConfigs:
  - name: Fire Bloom
    cost: 50
    category: Attack
    lifetime: 40
    description: "<align=center><b>Abilities:</b></align>\n\n<align=left><indent=60px>\u2022
      Launches fire projectiles at zombies in its lane.\n\n\u2022 Reliable damage
      dealer.\n\n\u2022 Good starter attack plant.</indent></align>"
    unlockCost: 0
  - name: Frost Flower
    cost: 75
    category: Trap
    lifetime: -1
    description: "<align=center><b>Abilities:</b></align>\n\n<align=left><indent=60px>\u2022
      Freezes zombies that enter its tile.\n\n\u2022 Stops enemy movement temporarily.\n\n\u2022
      Consumed after activation.</indent></align>"
    unlockCost: 0
  - name: Thorn Vine
    cost: 100
    category: Attack
    lifetime: 30
    description: "<align=center><b>Abilities:</b></align>\n\n<align=left><indent=60px>\u2022
      Very fast attack speed.\n\n\u2022 Continuously damages zombies.\n\n\u2022 Effective
      against weaker enemies.</indent></align>"
    unlockCost: 1000
  - name: Bomb Cactus
    cost: 150
    category: Trap
    lifetime: -1
    description: "<align=center><b>Abilities:</b></align>\n\n<align=left><indent=60px>\u2022
      Explodes when zombies enter its tile.\n\n\u2022 Deals area damage.\n\n\u2022
      Removed after detonation.</indent></align>"
    unlockCost: 2000
  - name: Magic Blossom
    cost: 400
    category: Attack
    lifetime: 25
    description: "<align=center><b>Abilities:</b></align>\n\n<align=left><indent=60px>\u2022
      Attacks zombies anywhere on the battlefield.\n\n\u2022 Uses rapid magical attacks.\n\n\u2022
      High damage over time.</indent></align>"
    unlockCost: 7500
  - name: Gun Guardian
    cost: 125
    category: Attack
    lifetime: -1
    description: "<align=center><b>Abilities:</b></align>\n\n<align=left><indent=60px>\u2022
      Shoots rapid physical projectiles at zombies.\n\n\u2022 High rate of fire.\n\n\u2022
      Excellent for sustaining damage lanes.</indent></align>"
    unlockCost: 3000
  - name: Sunflower Tree
    cost: 250
    category: Economy
    lifetime: 45
    description: "<align=center><b>Abilities:</b></align>\n\n<align=left><indent=60px>\u2022
      Generates coins over time.\n\n\u2022 Supports long-term economy growth.\n\n\u2022
      Helps build stronger defenses.</indent></align>"
    unlockCost: 3500
  - name: Guardian Oak
    cost: 200
    category: Tank
    lifetime: 10
    description: "<align=center><b>Abilities:</b></align>\n\n<align=left><indent=60px>\u2022
      Extremely high health.\n\n\u2022 Blocks zombies from advancing.\n\n\u2022 Protects
      nearby attack plants.</indent></align>"
    unlockCost: 5000
  - name: Lightning Lotus
    cost: 350
    category: Attack
    lifetime: 15
    description: "<align=center><b>Abilities:</b></align>\n\n<align=left><indent=60px>\u2022
      <b>Ability:</b> Fires lightning that jumps between nearby zombies.\n\n\u2022
      <b>Effect:</b> Damages multiple zombies with a single attack.\n\n\u2022 <b>Damage:</b>
      Highest on first target, reduced on chained targets.\n\n\u2022 <b>Purpose:</b>
      Strong against groups of zombies.</indent></align>"
    unlockCost: 6000
